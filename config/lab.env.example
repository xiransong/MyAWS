# Copy this file to config/lab.env and adjust values for your lab/account.

AWS_PROFILE=your-aws-profile
AWS_REGION=us-east-1
AWS_AVAILABILITY_ZONE=us-east-1a

# Use one of the following:
AWS_SECURITY_GROUP=your-security-group-name
# AWS_SECURITY_GROUP_ID=sg-0123456789abcdef0

AWS_KEY_NAME=your-keypair-name

BOOTSTRAP_AMI_ID=ami-xxxxxxxxxxxxxxxxx
BOOTSTRAP_INSTANCE_TYPE=t3.small
BOOTSTRAP_ROOT_SIZE_GB=20
BOOTSTRAP_INSTANCE_NAME=myaws-scratch-bootstrap

WORK_AMI_ID=ami-yyyyyyyyyyyyyyyyy
WORK_INSTANCE_TYPE=g4dn.xlarge
WORK_ROOT_SIZE_GB=500
WORK_INSTANCE_NAME=myaws-work-instance

SCRATCH_SIZE_GB=100
SCRATCH_MOUNT=/home/ubuntu/scratch
SCRATCH_LAYOUT_DIRS="repos data outputs transfer"
SCRATCH_TAG_PREFIX=myaws-scratch

EC2_DEFAULT_USER=ubuntu
